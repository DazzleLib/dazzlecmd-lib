[build-system]
requires = ["setuptools>=61.0", "wheel"]
build-backend = "setuptools.build_meta"

[project]
name = "{name}"
dynamic = ["version"]
description = "{description}"
readme = "README.md"
requires-python = ">=3.9"

dependencies = [
    "dazzlecmd-lib>={lib_min_version}",
]

[project.optional-dependencies]
dev = [
    "pytest>=7.0.0",
]

[project.scripts]
{command} = "{name_underscore}.cli:main"

[tool.setuptools.dynamic]
version = {attr = "{name_underscore}._version.__version__"}

[tool.setuptools.packages.find]
where = ["src"]
include = ["{name_underscore}*"]
