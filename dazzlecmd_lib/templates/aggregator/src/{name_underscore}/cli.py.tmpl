"""{name} -- a dazzlecmd-lib aggregator.

Generated by `dz new aggregator {name}`. The engine discovers tools under
{tools_dir}/<namespace>/<tool>/ (each with a {manifest} manifest), builds the
CLI, and dispatches. Library meta-commands (list/info/kit/tree/setup/version/
mode) are registered automatically; customize via engine.meta_registry
(override/register) before engine.run() -- see wtf-windows for the canonical
consumer example.
"""
import os
import sys

from dazzlecmd_lib import AggregatorEngine
from dazzlecmd_lib.aggregator_config import find_aggregator_root

from {name_underscore}._version import __version__, DISPLAY_VERSION


def main():
    # Anchor root-finding to THIS package's location (never bare/cwd): the
    # aggregator's identity is which package it is, not where it is invoked
    # from. aggregator.json at the project root is the marker.
    project_root = find_aggregator_root(os.path.dirname(os.path.abspath(__file__)))
    if project_root is None:
        print(
            "Error: could not find aggregator.json. Run from (or install -e) "
            "the {name} project tree.",
            file=sys.stderr,
        )
        return 1

    engine = AggregatorEngine.from_project(
        project_root,
        version_info=(DISPLAY_VERSION, __version__),
        is_root=True,
    )
    # engine.meta_registry.nest_all_under("{command}")  # uncomment when nest_all_under ships (dazzlecmd #47)
    return engine.run()


if __name__ == "__main__":
    sys.exit(main())
